---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
---

<DefaultLayout title="Contact">
  <PageHeader title="Contact" bgType="gradient" />
  <section class="my-12">
    <div class="container">
      <div class="grid grid-cols-1 gap-32 md:grid-cols-2">
        <div class="space-content">
          <p class="text-lg">
            Have a question? Want to get involed and contribute?<br>
            Feel free to contact us, we'll be happy to discuss!
          </p>

          <div class="gap-2xs flex items-center">
            <Icon aria-hidden="true" name="lucide:phone" size={20} class="flex-shrink-0" />
            <p>
              <span class="font-bold">Phone:</span>
              <Link href="tel:+12345678900">+1 (234) 567-8900</Link> (Matthieu)
            </p>
          </div>

          <div class="gap-2xs flex items-center">
            <Icon aria-hidden="true" name="lucide:mail" size={20} class="flex-shrink-0" />
            <p>
              <span class="font-bold">Email:</span>
              <Link href="mailto:lightfab-2027@univ-cotedazur.fr">lightfab-2027@univ-cotedazur.fr</Link>
            </p>
          </div>
          </div>
        </div>
    </div>
  </section>
</DefaultLayout>
